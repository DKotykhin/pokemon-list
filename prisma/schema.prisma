generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model PokemonList {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  pokemonItems PokemonItem[]
}

model PokemonItem {
  id           String   @id @default(uuid())
  listId       String   @map("list_id")
  pokemonApiId Int      @map("pokemon_api_id")
  name         String
  weight       Int
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  pokemonList PokemonList @relation(fields: [listId], references: [id], onDelete: Cascade)
}
